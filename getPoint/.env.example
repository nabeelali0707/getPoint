NODE_ENV=development
PORT=4000

# Runtime connection. For Supabase, use the transaction-mode pooler with pgbouncer.
DATABASE_URL=postgresql://postgres.PROJECT_ID:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Migration connection. For Supabase, use the session-mode pooler.
DIRECT_URL=postgresql://postgres.PROJECT_ID:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require

SUPABASE_URL=https://PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-for-api-broadcasts
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-or-publishable-key

JWT_ACCESS_SECRET=replace-with-at-least-32-characters-access-secret
JWT_REFRESH_SECRET=replace-with-at-least-32-characters-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

OTP_TTL_SECONDS=600
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Optional for Capacitor/static native builds. Leave empty for normal browser dev,
# where Next rewrites /api to API_URL.
NEXT_PUBLIC_API_BASE_URL=

# Optional. Without SMTP config, OTPs are logged to the API console in development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@nu.edu.pk

# Required for pnpm db:seed
ADMIN_EMAIL=admin@nu.edu.pk
ADMIN_PASSWORD=change-this-admin-password

# Required for pnpm db:seed:drivers.
# Change before real drivers log in. This bootstrap password is shared by seeded
# drivers and each driver should be told to change it on first login.
# TODO: auth.controller.ts currently has no password-change endpoint.
DRIVER_DEFAULT_PASSWORD=change-this-driver-bootstrap-password
