{
  "name": "point-management-system",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:api": "pnpm --filter @point/api dev",
    "build:shared": "pnpm --filter @point/shared-types build",
    "build:api": "pnpm build:shared && pnpm --filter @point/api build",
    "dev:web": "pnpm --filter @point/web dev",
    "build:web": "pnpm --filter @point/web build",
    "dev": "pnpm --filter @point/api --filter @point/web dev",
    "db:generate": "pnpm --filter @point/api db:generate",
    "db:migrate": "pnpm --filter @point/api db:migrate",
    "db:seed": "pnpm --filter @point/api db:seed"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
