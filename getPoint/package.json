{
  "name": "point-management-system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @point/api",
    "build:shared": "npm run build -w @point/shared-types",
    "build:api": "npm run build:shared && npm run build -w @point/api",
    "dev:web": "npm run dev -w @point/web",
    "build:web": "npm run build -w @point/web",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "db:generate": "npm run db:generate -w @point/api",
    "db:migrate": "npm run db:migrate -w @point/api",
    "db:seed": "npm run db:seed -w @point/api",
    "db:seed:drivers": "npm run db:seed:drivers -w @point/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  }
}
